{
  "id": "com.codexplayground.flatmagic.prototype",
  "name": "FlatMagic Prototype",
  "version": "0.1.0",
  "manifestVersion": 5,
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "24.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "flatmagicPanel",
      "label": {
        "default": "FlatMagic"
      },
      "minimumSize": {
        "width": 300,
        "height": 420
      },
      "maximumSize": {
        "width": 1200,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 720
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://127.0.0.1:8765",
        "http://localhost:8765"
      ]
    },
    "localFileSystem": "request"
  }
}
